---
layout: layouts/base.njk
title: About
metaTitle: "About Jonathan Everett — Nashville Photographer, Filmmaker, Actor"
metaDescription: "Nashville-based photographer, competitive bodybuilder, filmmaker, and actor. Specializing in physique photography, headshots, and creative portraiture."
---

<section class="page-hero">
  <div class="container">
    <h1 class="fade-in">About</h1>
    <p class="tagline fade-in">The person behind the lens.</p>
  </div>
</section>

<section class="section">
  <div class="about-content" style="max-width: 900px; margin: 0 auto; padding: 0 var(--space-md);">
    <div class="fade-in" style="float: right; width: 320px; margin: 0 0 var(--space-md) var(--space-lg); shape-outside: margin-box;">
      <img src="/images/about/portrait-7875.webp" alt="Jonathan Everett portrait" style="width: 100%; border-radius: 4px; display: block;">
    </div>

    <h2 class="fade-in" style="margin-bottom: var(--space-xs);">{{ about.title }}</h2>
    <p style="color: var(--accent); margin-bottom: var(--space-md); font-family: var(--serif); font-style: italic;" class="fade-in">{{ about.subtitle }}</p>

    <div class="fade-in">
      {% for paragraph in about.bio %}
      <p>{{ paragraph }}</p>
      {% endfor %}
    </div>

    <div style="margin-top: var(--space-md); clear: both;" class="fade-in">
      <a href="/contact/" class="btn btn-fill">Work With Me</a>
      <a href="{{ site.imdb }}" target="_blank" rel="noopener" class="btn" style="margin-left: var(--space-sm);">View IMDB</a>
    </div>
  </div>
</section>
