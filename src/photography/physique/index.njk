<section class="cta-banner">
  <div class="container fade-in">
    <h2>Ready to Book Your Session?</h2>
    <p>Whether it's show day or any day — let's capture the physique you've worked so hard to build.</p>
    <a href="/contact/?service=physique" class="btn btn-fill">Book Your Session</a>
  </div>
</section>

